generator client {
  provider        = "prisma-client-js"
  binaryTargets   = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Configurable campaign difficulty tier: volunteer cap and green-point reward.
/// Referenced by `campaigns.difficulty` (level) in incident-service.
model Difficulty {
  id String @id @default(uuid()) @db.Uuid

  /// Unique tier index (1 = easy … 4 = very hard).
  level Int @unique

  name String @db.VarChar(64)
  nameVi String? @map("name_vi") @db.VarChar(64)
  nameEn String? @map("name_en") @db.VarChar(64)

  /// Maximum approved volunteers; null means no limit (very hard).
  maxVolunteers Int? @map("max_volunteers")

  greenPoints Int @map("green_points")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([deletedAt])
  @@map("difficulties")
}

/// Per-user running balance of green points (reward-service is source of truth).
model UserGreenPointBalance {
  userId String @id @map("user_id") @db.Uuid

  balance Int @default(0)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("user_green_point_balances")
}

/// Append-only style ledger for all green-point earnings (campaign, upvote, referral, …).
/// Idempotency: unique (user, type, resource) while row is active — see partial index in migration.
model GreenPointTransaction {
  id String @id @default(uuid()) @db.Uuid

  userId String @map("user_id") @db.Uuid

  /// e.g. CAMPAIGN_COMPLETION, UPVOTE, REFERRAL
  type String @db.VarChar(64)

  /// Related entity id (campaign UUID, report UUID, etc.)
  resourceId String @map("resource_id") @db.Uuid

  /// What resource_id denotes: CAMPAIGN, REPORT, USER, …
  resourceType String @map("resource_type") @db.VarChar(64)

  points Int

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([userId])
  @@index([resourceType, resourceId])
  @@index([type])
  @@map("green_point_transactions")
}

model Media {
  id   String @id @default(uuid()) @db.Uuid
  url  String
  type String @db.VarChar(50)

  createdBy String? @map("created_by") @db.Uuid
  updatedBy String? @map("updated_by") @db.Uuid

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  gifts Gift[]

  @@index([type])
  @@index([deletedAt])
  @@map("media")
}

/// Catalog item users can redeem for green points.
model Gift {
  id String @id @default(uuid()) @db.Uuid

  name String @db.VarChar(255)
  nameVi String? @map("name_vi") @db.VarChar(255)
  nameEn String? @map("name_en") @db.VarChar(255)

  mediaId String? @map("media_id") @db.Uuid

  description String @db.Text
  descriptionVi String? @map("description_vi") @db.Text
  descriptionEn String? @map("description_en") @db.Text

  /// Green points required to redeem once.
  greenPoints Int @map("green_points")

  /// Remaining stock; null means unlimited.
  stockRemaining Int? @map("stock_remaining")

  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  redemptions GiftRedemption[]
  media       Media?           @relation(fields: [mediaId], references: [id], onDelete: Restrict)

  @@index([deletedAt])
  @@index([isActive])
  @@index([mediaId])
  @@map("gifts")
}

model GiftRedemption {
  id String @id @default(uuid()) @db.Uuid

  userId String @map("user_id") @db.Uuid

  giftId String @map("gift_id") @db.Uuid

  greenPointsSpent Int @map("green_points_spent")

  createdAt DateTime @default(now()) @map("created_at")

  gift Gift @relation(fields: [giftId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([giftId])
  @@map("gift_redemptions")
}

/// Outbox + tracking for reward-service background jobs (e.g. green-point SQS worker, @da2/queue).
model RewardBackgroundJob {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  jobType     String    @map("job_type") @db.VarChar(100)
  payload     Json
  status      Int       @default(12)
  attempts    Int       @default(0)
  maxAttempts Int       @default(5) @map("max_attempts")
  processedAt DateTime? @map("processed_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@index([jobType, status])
  @@index([status])
  @@map("reward_background_jobs")
}
