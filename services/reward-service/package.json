{
  "name": "reward-service",
  "version": "1.0.0",
  "description": "DA2 reward rules: campaign difficulties (volunteer caps, green points)",
  "main": "dist/index.js",
  "scripts": {
    "build:constants": "npm ci --prefix ../../shared/da2-constants && npm run build --prefix ../../shared/da2-constants",
    "build:express-swagger": "npm ci --prefix ../../shared/express-swagger && npm run build --prefix ../../shared/express-swagger",
    "build:queue": "npm ci --prefix ../../shared/da2-queue && npm run build --prefix ../../shared/da2-queue",
    "prebuild": "npm run build:constants && npm run build:queue && npm run build:express-swagger",
    "build": "tsc",
    "start": "node dist/index.js",
    "worker": "node dist/worker.js",
    "start:production": "npm run prisma:migrate:deploy && npm run start",
    "start:worker:production": "npm run prisma:migrate:deploy && npm run worker",
    "dev": "nodemon",
    "dev:worker": "ts-node -r tsconfig-paths/register src/worker.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "prisma:seed": "prisma db seed"
  },
  "prisma": {
    "seed": "ts-node -r tsconfig-paths/register prisma/seed.ts"
  },
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-sqs": "^3.1024.0",
    "@da2/constants": "file:../../shared/da2-constants",
    "@da2/express-swagger": "file:../../shared/express-swagger",
    "@da2/queue": "file:../../shared/da2-queue",
    "@prisma/client": "^6.19.2",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.22.1",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "swagger-ui-express": "^5.0.1",
    "ts-json-schema-generator": "^2.4.0"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.25",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.19.37",
    "@types/swagger-ui-express": "^4.1.8",
    "nodemon": "^3.1.11",
    "prisma": "^6.19.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.3"
  }
}
