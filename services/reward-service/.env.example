# Suggested local ports: identity 3000 | incident 3001 | reward 3002 | notification 3003 | api-gateway 8080

PORT=3002
NODE_ENV=development

DATABASE_URL="postgresql://postgres:password@localhost:5432/rewarddb?schema=public"

JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
CORS_ORIGIN=*
SWAGGER_SERVER_URL=http://localhost:3002

# Internal routes (/internal/v1/...) — must match incident-service INTERNAL_REWARD_API_KEY
INTERNAL_REWARD_API_KEY=change-me-internal-only

# LocalStack (docker-compose from be/docker-compose.yml, port 4566)
SQS_GREEN_POINT_QUEUE_URL=http://localhost:4566/000000000000/green-point
AWS_GREENPOINT_ENDPOINT_URL=http://localhost:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DEFAULT_REGION=us-east-1
