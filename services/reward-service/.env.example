# Suggested local ports: identity 3000 | incident 3001 | reward 3002 | notification 3003 | api-gateway 8081

PORT=3002
NODE_ENV=development

DATABASE_URL="postgresql://postgres:password@ecolink-postgres:5433/rewarddb?schema=public"

JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
CORS_ORIGIN=*
SWAGGER_SERVER_URL=http://localhost:3002

# Internal routes (/internal/v1/...) — must match incident-service INTERNAL_REWARD_API_KEY
INTERNAL_REWARD_API_KEY=change-me-internal-only

# LocalStack (docker-compose from be/docker-compose.yml, port 4566)
SQS_GREEN_POINT_QUEUE_URL=http://localhost:4566/000000000000/green-point
SQS_FACEBOOK_RECOGNITION_QUEUE_URL=http://localhost:4566/000000000000/facebook-recognition
AWS_GREENPOINT_ENDPOINT_URL=http://localhost:4566
# Optional: webhook endpoint that also receives the recognition payload.
# FACEBOOK_RECOGNITION_WEBHOOK_URL=https://your-webhook.example.com/facebook/recognition
