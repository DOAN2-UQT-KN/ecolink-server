# Suggested local ports: identity 3000 | incident 3001 | reward 3002 | notification 3003 | api-gateway 8080

PORT=3003
NODE_ENV=development
DATABASE_URL="postgresql://postgres:password@localhost:5432/notificationdb?schema=public"

# Same secret as identity-service JWT signing (for Bearer auth on /my and /:id/read)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Resolve recipient email for queued email jobs (must match identity-service INTERNAL_IDENTITY_API_KEY)
IDENTITY_SERVICE_URL=http://localhost:3000
INTERNAL_IDENTITY_API_KEY=change-me-internal-only

# Required for POST /api/v1/notifications/jobs from other services
INTERNAL_NOTIFICATION_API_KEY=change-me-internal-only

# SQS (same pattern as incident-service report analysis)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
# LocalStack example: http://localhost:4566/000000000000/notification-send
SQS_NOTIFICATION_QUEUE_URL=http://localhost:4566/000000000000/notification-send

# Optional: for LocalStack / custom endpoint
# AWS_SQS_ENDPOINT=http://localhost:4566

# Worker tuning (optional)
# WORKER_SQS_WAIT_TIME_SECONDS=20
# WORKER_SQS_VISIBILITY_TIMEOUT_SECONDS=120
# WORKER_BATCH_SIZE=5
# WORKER_MAX_RECEIVE_COUNT=5
# WORKER_RETRY_BASE_SECONDS=30
# WORKER_MAX_RETRY_DELAY_SECONDS=900

# Optional SMTP — if unset, email rows are still stored but mail is not sent
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

CORS_ORIGIN=*
SWAGGER_SERVER_URL=http://localhost:3003
