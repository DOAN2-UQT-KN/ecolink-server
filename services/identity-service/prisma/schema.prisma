// Prisma schema for Identity Service

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email             String  @unique
  name              String
  password          String
  avatar            String?
  bio               String?
  emailVerified     Boolean @default(false)
  verificationToken String?

  roleId String @db.Uuid
  role   Role   @relation(fields: [roleId], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt @default(now())
  deletedAt DateTime?

  @@index([email])
  @@index([roleId])
  @@index([deletedAt])
  @@map("users")
}

model Role {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String  @unique
  description String?

  users              User[]
  rolePermissionSets RolePermissionSet[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt @default(now())
  deletedAt DateTime?

  @@map("roles")
}

model PermissionSet {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String   @unique
  description String?
  permissions String[]

  rolePermissionSets RolePermissionSet[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt @default(now())
  deletedAt DateTime?

  @@map("permission_sets")
}

model RolePermissionSet {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  roleId String @db.Uuid
  role   Role   @relation(fields: [roleId], references: [id])

  permissionSetId String        @db.Uuid
  permissionSet   PermissionSet @relation(fields: [permissionSetId], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt @default(now())
  deletedAt DateTime?

  @@unique([roleId, permissionSetId])
  @@index([roleId])
  @@index([permissionSetId])

  @@map("role_permission_sets")
}