// Prisma schema for Identity Service

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email             String  @unique
  name              String
  password          String
  avatar            String?
  bio               String?
  emailVerified     Boolean @default(false)
  verificationToken String?

  /// Last known coordinates (WGS84); set via profile update.
  latitude          Float?
  longitude         Float?
  locationUpdatedAt DateTime? @map("location_updated_at")

  roleId String @db.Uuid
  role   Role   @relation(fields: [roleId], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt @default(now())
  deletedAt DateTime?

  authTokens AuthToken[]

  @@index([email])
  @@index([roleId])
  @@index([deletedAt])
  @@map("users")
}

// Hashed token only (never store plain). type: REFRESH, PASSWORD_RESET (see AuthTokenType).
model AuthToken {
  id        String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String @map("user_id") @db.Uuid
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type      String   @db.VarChar(32)
  tokenHash String   @map("token_hash") @db.VarChar(64)
  expiresAt DateTime @map("expires_at")

  revokedAt DateTime? @map("revoked_at")
  usedAt    DateTime? @map("used_at")
  metadata  Json?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([tokenHash])
  @@index([userId, type])
  @@index([expiresAt])
  @@map("auth_tokens")
}

model Role {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String  @unique
  description String?

  users              User[]
  rolePermissionSets RolePermissionSet[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt @default(now())
  deletedAt DateTime?

  @@map("roles")
}

model PermissionSet {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String   @unique
  description String?
  permissions String[]

  rolePermissionSets RolePermissionSet[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt @default(now())
  deletedAt DateTime?

  @@map("permission_sets")
}

model RolePermissionSet {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  roleId String @db.Uuid
  role   Role   @relation(fields: [roleId], references: [id])

  permissionSetId String        @db.Uuid
  permissionSet   PermissionSet @relation(fields: [permissionSetId], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt @default(now())
  deletedAt DateTime?

  @@unique([roleId, permissionSetId])
  @@index([roleId])
  @@index([permissionSetId])

  @@map("role_permission_sets")
}