# Identity Service Configuration
#
# Suggested local ports (each service on its own port):
#   identity 3000 | incident 3001 | reward 3002 | notification 3003 | api-gateway 8081

# Server
PORT=3000
NODE_ENV=development

# Database
DATABASE_URL="postgresql://postgres:postgres@ecolink.id.vn:5433/identitydb?schema=public"

# Server-to-server (e.g. notification-service GET /internal/v1/users/:id/email)
INTERNAL_IDENTITY_API_KEY=change-me-internal-only

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=30d
JWT_REFRESH_EXPIRES_IN=30d

# Optional: organization contact-email verification tokens (incident-service). Default 72h.
# ORG_CONTACT_EMAIL_TOKEN_TTL_MS=

# CORS
CORS_ORIGIN=*
