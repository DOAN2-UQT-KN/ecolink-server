# Identity Service Configuration - Production

# Server
PORT=3000
NODE_ENV=production

# Database
# Note: In production, these should ideally be overridden by K8s Secrets
DATABASE_URL="postgresql://postgres:password@postgres-postgis-postgresql:5432/identitydb?schema=public"

# JWT
JWT_SECRET=replace-with-a-very-long-production-secret-key
JWT_EXPIRES_IN=30d
JWT_REFRESH_EXPIRES_IN=30d

# CORS
CORS_ORIGIN=https://ecolink.id.vn
