// Prisma schema for Incident Service

generator client {
    provider        = "prisma-client-js"
    previewFeatures = ["postgresqlExtensions"]
}

datasource db {
    provider   = "postgresql"
    url        = env("DATABASE_URL")
    extensions = [uuidOssp(map: "uuid-ossp"), postgis]
}

model Report {
    id          String  @id @default(uuid()) @db.Uuid
    userId      String? @map("user_id") @db.Uuid
    title       String? @db.VarChar(200)
    description String?

    wasteType     String? @map("waste_type") @db.VarChar(100)
    severityLevel Int?    @map("severity_level")

    // PostGIS Geography point stored as raw - we'll use raw queries for spatial operations
    latitude  Float?
    longitude Float?

    status String? @default("pending") @db.VarChar(50)
    // pending
    // approved
    // in_progress
    // completed
    // rejected

    aiVerified Boolean @default(false) @map("ai_verified")

    createdAt DateTime  @default(now()) @map("created_at")
    updatedAt DateTime  @updatedAt @map("updated_at")
    deletedAt DateTime? @map("deleted_at")

    // Relations
    reportResults       ReportResult[]
    reportMediaFiles    ReportMediaFile[]
    reportTasks         ReportTask[]
    reportJoiningRequest ReportJoiningRequest[]
    reportIssues        ReportIssue[]
    reportManagers      ReportManager[]
    aiAnalysisLogs      AiAnalysisLog[]

    @@index([userId])
    @@index([status])
    @@index([deletedAt])
    @@map("reports")
}

model ReportResult {
    id                   String @id @default(uuid()) @db.Uuid
    reportId             String @map("report_id") @db.Uuid
    submittedByManagerId String @map("submitted_by_manager_id") @db.Uuid

    description String?

    status String @default("PENDING_APPROVAL") @db.VarChar(30)
    // PENDING_APPROVAL
    // APPROVED
    // REJECTED

    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @updatedAt @map("updated_at")

    // Relations
    report          Report            @relation(fields: [reportId], references: [id])
    reportMediaFiles ReportMediaFile[]

    @@index([reportId])
    @@index([submittedByManagerId])
    @@map("report_results")
}

model ReportMediaFile {
    id             String  @id @default(uuid()) @db.Uuid
    reportId       String? @map("report_id") @db.Uuid
    reportResultId String? @map("report_result_id") @db.Uuid

    fileUrl String @map("file_url")

    stage String? @db.VarChar(20)
    // BEFORE
    // AFTER

    uploadedBy String? @map("uploaded_by") @db.Uuid

    createdAt DateTime  @default(now()) @map("created_at")
    updatedAt DateTime  @updatedAt @map("updated_at")
    deletedAt DateTime? @map("deleted_at")

    // Relations
    report       Report?       @relation(fields: [reportId], references: [id])
    reportResult ReportResult? @relation(fields: [reportResultId], references: [id])

    @@index([reportId])
    @@index([reportResultId])
    @@map("report_media_files")
}

model ReportTask {
    id       String  @id @default(uuid()) @db.Uuid
    reportId String? @map("report_id") @db.Uuid

    title       String? @db.VarChar(200)
    description String?

    status String @default("open") @db.VarChar(50)
    // open
    // in_progress
    // completed
    // cancelled

    scheduledTime DateTime? @map("scheduled_time")

    createdBy String? @map("created_by") @db.Uuid

    createdAt DateTime  @default(now()) @map("created_at")
    updatedAt DateTime  @updatedAt @map("updated_at")
    deletedAt DateTime? @map("deleted_at")

    // Relations
    report          Report?          @relation(fields: [reportId], references: [id])
    taskAssignments TaskAssignment[]

    @@index([reportId])
    @@index([status])
    @@map("report_tasks")
}

model TaskAssignment {
    id           String  @id @default(uuid()) @db.Uuid
    reportTaskId String? @map("report_task_id") @db.Uuid
    volunteerId  String? @map("volunteer_id") @db.Uuid

    createdAt DateTime  @default(now()) @map("created_at")
    updatedAt DateTime  @updatedAt @map("updated_at")
    deletedAt DateTime? @map("deleted_at")

    // Relations
    reportTask ReportTask? @relation(fields: [reportTaskId], references: [id])

    @@index([reportTaskId])
    @@index([volunteerId])
    @@map("task_assignments")
}

model ReportJoiningRequest {
    id          String  @id @default(uuid()) @db.Uuid
    reportId    String? @map("report_id") @db.Uuid
    volunteerId String? @map("volunteer_id") @db.Uuid

    status String @default("pending") @db.VarChar(50)
    // pending
    // approved
    // rejected

    createdAt DateTime  @default(now()) @map("created_at")
    updatedAt DateTime  @updatedAt @map("updated_at")
    deletedAt DateTime? @map("deleted_at")

    // Relations
    report Report? @relation(fields: [reportId], references: [id])

    @@index([reportId])
    @@index([volunteerId])
    @@index([status])
    @@map("report_joining_request")
}

model ReportIssue {
    id         String  @id @default(uuid()) @db.Uuid
    reportId   String? @map("report_id") @db.Uuid
    reporterId String? @map("reporter_id") @db.Uuid

    issueType    String? @map("issue_type") @db.VarChar(50)
    description  String?
    mediaFileUrl String? @map("media_file_url")

    createdAt DateTime  @default(now()) @map("created_at")
    updatedAt DateTime  @updatedAt @map("updated_at")
    deletedAt DateTime? @map("deleted_at")

    // Relations
    report Report? @relation(fields: [reportId], references: [id])

    @@index([reportId])
    @@index([reporterId])
    @@map("report_issues")
}

model ReportManager {
    reportId String @map("report_id") @db.Uuid
    userId   String @map("user_id") @db.Uuid

    assignedBy String?   @map("assigned_by") @db.Uuid
    assignedAt DateTime  @default(now()) @map("assigned_at")
    createdAt  DateTime  @default(now()) @map("created_at")
    deletedAt  DateTime? @map("deleted_at")

    // Relations
    report Report @relation(fields: [reportId], references: [id])

    @@id([reportId, userId])
    @@index([userId])
    @@map("report_managers")
}

model AiAnalysisLog {
    id       String  @id @default(uuid()) @db.Uuid
    reportId String? @map("report_id") @db.Uuid

    detectedWasteType String? @map("detected_waste_type") @db.VarChar(100)
    confidence        Float?
    boundingBox       Json?   @map("bounding_box")

    processedAt DateTime @default(now()) @map("processed_at")

    // Relations
    report Report? @relation(fields: [reportId], references: [id])

    @@index([reportId])
    @@map("ai_analysis_logs")
}

model BackgroundJob {
    id String @id @default(uuid()) @db.Uuid

    jobType String @map("job_type") @db.VarChar(100)
    payload Json

    status      String   @default("queued") @db.VarChar(30)
    attempts    Int      @default(0)
    maxAttempts Int      @default(5) @map("max_attempts")
    runAfter    DateTime @default(now()) @map("run_after")

    processedAt DateTime? @map("processed_at")
    createdAt   DateTime  @default(now()) @map("created_at")
    updatedAt   DateTime  @updatedAt @map("updated_at")

    @@index([jobType, status, runAfter])
    @@index([status, runAfter])
    @@map("background_jobs")
}
