// Prisma schema for Incident Service

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
  binaryTargets   = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [uuidOssp(map: "uuid-ossp"), postgis]
}

model Report {
  id         String  @id @default(uuid()) @db.Uuid
  campaignId String? @map("campaign_id") @db.Uuid
  userId     String? @map("user_id") @db.Uuid
  title      String? @db.VarChar(200)
  description String?

  wasteType     String? @map("waste_type") @db.VarChar(100)
  severityLevel Int?    @map("severity_level")

  // PostGIS Geography point stored as raw - we'll use raw queries for spatial operations
  latitude  Float?
  longitude Float?

  /** Human-readable location text (e.g. street / place name from reverse geocoding). */
  detailAddress String? @map("detail_address")

  status Int? @default(12)

  /** Admin moderation: only admins can set true (see verify endpoint). */
  isVerify Boolean @default(false) @map("is_verify")

  aiVerified Boolean @default(false) @map("ai_verified")

  createdBy String? @map("created_by") @db.Uuid
  updatedBy String? @map("updated_by") @db.Uuid

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  // Relations
  reportMediaFiles ReportMediaFile[]
  reportIssues     ReportIssue[]
  aiAnalysisLogs   AiAnalysisLog[]
  campaign         Campaign?         @relation(fields: [campaignId], references: [id])

  @@index([campaignId])
  @@index([userId])
  @@index([status])
  @@index([deletedAt])
  @@map("reports")
}

model Campaign {
  id          String  @id @default(uuid()) @db.Uuid
  title       String  @db.VarChar(200)
  description String?
  status      Int     @default(12)
  startDate   DateTime? @map("start_date")
  endDate     DateTime? @map("end_date")
  detailAddress String? @map("detail_address") @db.VarChar(255)
  latitude    Float?
  longitude   Float?
  radiusKm    Float? @map("radius_km")

  /** Level key into reward-service `difficulties` (volunteer cap, green points). */
  difficulty Int @default(1)

  organizationId String @map("organization_id") @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id])

  createdBy String? @map("created_by") @db.Uuid
  updatedBy String? @map("updated_by") @db.Uuid

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  reports                 Report[]
  campaignManagers        CampaignManager[]
  campaignJoiningRequests CampaignJoiningRequest[]
  campaignTasks           CampaignTask[]
  campaignSubmissions     CampaignSubmission[]
  campaignResults         CampaignResult[]

  @@index([status])
  @@index([createdBy])
  @@index([organizationId])
  @@index([deletedAt])
  @@map("campaigns")
}

model Media {
  id   String @id @default(uuid()) @db.Uuid
  url  String
  type String @db.VarChar(50)

  createdBy String? @map("created_by") @db.Uuid
  updatedBy String? @map("updated_by") @db.Uuid

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([type])
  @@index([deletedAt])
  @@map("media")
}

model ReportMediaFile {
  id       String  @id @default(uuid()) @db.Uuid
  reportId String? @map("report_id") @db.Uuid

  mediaId String @map("media_id") @db.Uuid

  uploadedBy String? @map("uploaded_by") @db.Uuid

  createdBy String? @map("created_by") @db.Uuid
  updatedBy String? @map("updated_by") @db.Uuid

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  // Relations
  report Report? @relation(fields: [reportId], references: [id])

  @@index([reportId])
  @@index([mediaId])
  @@map("report_media_files")
}

model CampaignTask {
  id         String  @id @default(uuid()) @db.Uuid
  campaignId String? @map("campaign_id") @db.Uuid

  title       String? @db.VarChar(200)
  description String?

  status Int @default(12)

  scheduledTime DateTime? @map("scheduled_time")

  createdBy String? @map("created_by") @db.Uuid
  updatedBy String? @map("updated_by") @db.Uuid

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  // Relations
  campaign                Campaign?                @relation(fields: [campaignId], references: [id])
  campaignTaskAssignments CampaignTaskAssignment[]

  @@index([campaignId])
  @@index([status])
  @@map("campaign_tasks")
}

model CampaignTaskAssignment {
  id             String  @id @default(uuid()) @db.Uuid
  campaignTaskId String? @map("campaign_task_id") @db.Uuid
  volunteerId    String? @map("volunteer_id") @db.Uuid

  createdBy String? @map("created_by") @db.Uuid
  updatedBy String? @map("updated_by") @db.Uuid

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  // Relations
  campaignTask CampaignTask? @relation(fields: [campaignTaskId], references: [id])

  @@index([campaignTaskId])
  @@index([volunteerId])
  @@map("campaign_task_assignments")
}

model CampaignJoiningRequest {
  id          String  @id @default(uuid()) @db.Uuid
  campaignId  String? @map("campaign_id") @db.Uuid
  volunteerId String? @map("volunteer_id") @db.Uuid

  status Int @default(12)

  createdBy String? @map("created_by") @db.Uuid
  updatedBy String? @map("updated_by") @db.Uuid

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  // Relations
  campaign Campaign? @relation(fields: [campaignId], references: [id])

  @@index([campaignId])
  @@index([volunteerId])
  @@index([status])
  @@map("campaign_joining_requests")
}

// A submission is created by a campaign manager to document cleanup work.
// One campaign can have multiple submissions over time.
model CampaignSubmission {
  id          String  @id @default(uuid()) @db.Uuid
  campaignId  String  @map("campaign_id") @db.Uuid
  submittedBy String  @map("submitted_by") @db.Uuid // manager who submitted

  title       String? @db.VarChar(200)
  description String?

  status Int @default(12) // PENDING → in review / approved / rejected after process

  createdBy String? @map("created_by") @db.Uuid
  updatedBy String? @map("updated_by") @db.Uuid

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  // Relations
  campaign        Campaign         @relation(fields: [campaignId], references: [id])
  campaignResults CampaignResult[]

  @@index([campaignId])
  @@index([submittedBy])
  @@index([status])
  @@index([deletedAt])
  @@map("campaign_submissions")
}

// A result is cleanup evidence for a campaign. While draft (no submission yet), campaignSubmissionId is null.
model CampaignResult {
  id                   String  @id @default(uuid()) @db.Uuid
  campaignId           String  @map("campaign_id") @db.Uuid
  campaignSubmissionId String? @map("campaign_submission_id") @db.Uuid

  title       String  @db.VarChar(200)
  description String?

  createdBy String? @map("created_by") @db.Uuid
  updatedBy String? @map("updated_by") @db.Uuid

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  // Relations
  campaign             Campaign              @relation(fields: [campaignId], references: [id])
  campaignSubmission   CampaignSubmission?   @relation(fields: [campaignSubmissionId], references: [id])
  campaignResultFiles  CampaignResultFile[]

  @@index([campaignId])
  @@index([campaignSubmissionId])
  @@index([deletedAt])
  @@map("campaign_results")
}

// Media files attached to a campaign result.
model CampaignResultFile {
  id               String @id @default(uuid()) @db.Uuid
  campaignResultId String @map("campaign_result_id") @db.Uuid
  mediaId          String @map("media_id") @db.Uuid

  createdBy String? @map("created_by") @db.Uuid
  updatedBy String? @map("updated_by") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  campaignResult CampaignResult @relation(fields: [campaignResultId], references: [id])

  @@index([campaignResultId])
  @@index([mediaId])
  @@map("campaign_result_files")
}

model ReportIssue {
  id         String  @id @default(uuid()) @db.Uuid
  reportId   String? @map("report_id") @db.Uuid
  reporterId String? @map("reporter_id") @db.Uuid

  issueType    String? @map("issue_type") @db.VarChar(50)
  description  String?
  mediaFileUrl String? @map("media_file_url")

  createdBy String? @map("created_by") @db.Uuid
  updatedBy String? @map("updated_by") @db.Uuid

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  // Relations
  report Report? @relation(fields: [reportId], references: [id])

  @@index([reportId])
  @@index([reporterId])
  @@map("report_issues")
}

model CampaignManager {
  campaignId String @map("campaign_id") @db.Uuid
  userId     String @map("user_id") @db.Uuid

  assignedBy String?   @map("assigned_by") @db.Uuid
  assignedAt DateTime  @default(now()) @map("assigned_at")
  createdBy  String?   @map("created_by") @db.Uuid
  updatedBy  String?   @map("updated_by") @db.Uuid
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")

  // Relations
  campaign Campaign @relation(fields: [campaignId], references: [id])

  @@id([campaignId, userId])
  @@index([campaignId])
  @@index([userId])
  @@map("campaign_managers")
}

model AiAnalysisLog {
  id       String @id @default(uuid()) @db.Uuid
  reportId String @map("report_id") @db.Uuid

  reportMediaFileId String? @map("report_media_file_id") @db.Uuid
  mediaId           String? @map("media_id") @db.Uuid
  detections        Int?

  createdBy String? @map("created_by") @db.Uuid
  updatedBy String? @map("updated_by") @db.Uuid

  processedAt DateTime @default(now()) @map("processed_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  report      Report   @relation(fields: [reportId], references: [id])

  @@index([reportId])
  @@index([reportMediaFileId])
  @@index([mediaId])
  @@map("ai_analysis_logs")
}

model BackgroundJob {
  id String @id @default(uuid()) @db.Uuid

  jobType String @map("job_type") @db.VarChar(100)
  payload Json

  status      Int      @default(12)
  attempts    Int      @default(0)
  maxAttempts Int      @default(5) @map("max_attempts")
  runAfter    DateTime @default(now()) @map("run_after")

  createdBy String? @map("created_by") @db.Uuid
  updatedBy String? @map("updated_by") @db.Uuid

  processedAt DateTime? @map("processed_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@index([jobType, status, runAfter])
  @@index([status, runAfter])
  @@map("background_jobs")
}

model Vote {
  id             String    @id @default(uuid()) @db.Uuid
  userId         String    @map("user_id") @db.Uuid
  /** 1 = upvote, -1 = downvote, 0 = cancelled / neutral */
  value          Int
  resourceType   String    @map("resource_type") @db.VarChar(32)
  resourceId     String    @map("resource_id") @db.Uuid

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@unique([userId, resourceType, resourceId])
  @@index([resourceType, resourceId])
  @@index([userId])
  @@map("votes")
}

model SavedResource {
  id           String @id @default(uuid()) @db.Uuid
  userId       String @map("user_id") @db.Uuid
  resourceId   String @map("resource_id") @db.Uuid
  resourceType String @map("resource_type") @db.VarChar(32)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@unique([userId, resourceType, resourceId])
  @@index([resourceType, resourceId])
  @@index([userId])
  @@map("saved_resources")
}

/** A group with exactly one owner (`ownerId`). Other users join via `OrganizationJoiningRequest`. */
model Organization {
  id          String  @id @default(uuid()) @db.Uuid
  name        String  @db.VarChar(200)
  description String?

  /** Public logo image URL (required on create). */
  logoUrl String @map("logo_url") @db.VarChar(2048)
  /** Optional public background / banner image URL. */
  backgroundUrl String? @map("background_url") @db.VarChar(2048)
  contactEmail String? @map("contact_email") @db.VarChar(320)

  /** Whether `contactEmail` has been confirmed (e.g. OTP); not set by create body. */
  isEmailVerified Boolean @default(false) @map("is_email_verified")
  /** Lifecycle: `GlobalStatus._STATUS_PENDING` until admin approves (`ACTIVE`) or rejects (`INACTIVE`). */
  status Int @default(12)

  ownerId String @map("owner_id") @db.Uuid

  createdBy String? @map("created_by") @db.Uuid
  updatedBy String? @map("updated_by") @db.Uuid

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  members      OrganizationMember[]
  joinRequests OrganizationJoiningRequest[]
  campaigns    Campaign[]

  @@index([ownerId])
  @@index([deletedAt])
  @@map("organizations")
}

/** Approved members (owner is not duplicated here; use `Organization.ownerId`). */
model OrganizationMember {
  organizationId String @map("organization_id") @db.Uuid
  userId         String @map("user_id") @db.Uuid

  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  organization Organization @relation(fields: [organizationId], references: [id])

  @@id([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
  @@map("organization_members")
}

model OrganizationJoiningRequest {
  id             String  @id @default(uuid()) @db.Uuid
  organizationId String  @map("organization_id") @db.Uuid
  requesterId    String  @map("requester_id") @db.Uuid

  status Int @default(12)

  createdBy String? @map("created_by") @db.Uuid
  updatedBy String? @map("updated_by") @db.Uuid

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@index([requesterId])
  @@index([status])
  @@map("organization_joining_requests")
}
