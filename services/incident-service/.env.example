# Copy to .env for local development

PORT=3001
NODE_ENV=development

DATABASE_URL="postgresql://postgres:postgres@ecolink.id.vn:5433/incidentdb?schema=public"

JWT_SECRET=local-dev-secret-key-12345
JWT_EXPIRES_IN=30m
JWT_REFRESH_EXPIRES_IN=30d

CORS_ORIGIN=*

# Identity service (opaque tokens for organization contact-email verification links)
# IDENTITY_SERVICE_URL=http://localhost:3000
# INTERNAL_IDENTITY_API_KEY=must-match-identity-service

# URL of this service as used in emails (verification link). Defaults to http://localhost:PORT
# PUBLIC_INCIDENT_API_URL=http://localhost:3001

# Frontend base URL for redirects after contact email verification
# FRONTEND_APP_URL=http://localhost:3000

# Display name in verification emails (notification templates)
# APP_NAME=DA2

# Enqueue contact verification email via notification-service (optional; logs warning if unset)
# NOTIFICATION_SERVICE_URL=http://localhost:3002
# INTERNAL_NOTIFICATION_API_KEY=must-match-notification-service

# SQS (LocalStack)
AWS_REGION=ap-southeast-1
AWS_ENDPOINT_URL=http://localhost:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
SQS_REPORT_ANALYSIS_QUEUE_URL=http://localhost:4566/000000000000/durable-background-job
