# Identity Service Configuration - Local Development

# Server
PORT=3001
NODE_ENV=development

DATABASE_URL="postgresql://postgres:postgres@ecolink.id.vn:5433/incidentdb?schema=public"

# JWT
JWT_SECRET=local-dev-secret-key-12345
JWT_EXPIRES_IN=30m
JWT_REFRESH_EXPIRES_IN=30d

# CORS
CORS_ORIGIN=*

# SQS (LocalStack)
AWS_REGION=ap-southeast-1
AWS_ENDPOINT_URL=http://localhost:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
SQS_REPORT_ANALYSIS_QUEUE_URL=http://localhost:4566/000000000000/durable-background-job
